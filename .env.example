# Copy this file to .env and adjust values for your machine.
# .env is ignored by git.

# Directory where downloaded files are stored.
# Default: ./downloads (inside the project)
DOWNLOAD_DIR="./downloads"

# Hours to keep generated preview files.
# Default: 24
PREVIEW_TTL_HOURS=24

# Automatic retry/resume when a download is interrupted.
# Retries are in addition to yt-dlp internal retries.
AUTO_RESUME_RETRIES=3

# Seconds to wait between automatic resume attempts.
AUTO_RESUME_DELAY_SECONDS=5

# Flask bind host and port.
# For local runs, 127.0.0.1 is safer.
HOST=127.0.0.1
PORT=8899
